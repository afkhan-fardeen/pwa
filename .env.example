# Copy to .env.local and adjust. Used by Next.js and Drizzle CLI.
# After changing .env.local, restart `npm run dev` (or your production process).

DATABASE_URL="postgresql://halqa:halqa_dev_password@localhost:5432/halqa"

# Dev: wipe all data then re-seed demo users (destructive)
# npm run db:reset
# npm run db:reset:seed

# --- NextAuth (Auth.js) — required ---
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# Public URL of this app (no trailing slash). Used in password-reset and reminder links.
# Must match what you type in the browser (scheme + host + port).
# Local: http://localhost:3000
# Phone / another PC on LAN: http://YOUR_LAN_IP:3000
# Production: https://your-domain.com
AUTH_URL="http://localhost:3000"

# --- Outgoing email (required for password reset, registration mail, daily reminders) ---
# Without SMTP_USER + SMTP_PASS, reset links are NOT emailed (you will see a server warning).
#
# Gmail: enable 2-Step Verification, then create an App Password (Google Account → Security).
# Use the 16-character app password as SMTP_PASS — not your normal Gmail password.
#
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your@gmail.com"
SMTP_PASS="your-16-char-app-password"
# Display name + address (what recipients see). Default without this: "Qalbee Support" + SMTP_USER.
EMAIL_FROM="Qalbee Support <your@gmail.com>"

# Optional: scripts/seed-admin.ts
# SEED_ADMIN_EMAIL="admin@example.com"
# SEED_ADMIN_PASSWORD="ChangeMe123"

# Vercel Cron (or any scheduler) — GET /api/cron/reminders with Authorization: Bearer <secret>
# In-app reminders work without SMTP; email reminders need SMTP_* above. See docs/cron-reminders.md
# CRON_SECRET="openssl-rand-hex-32"

# Local dev keeps DATABASE_URL pointing at Docker/local Postgres (above).
# On Vercel Production, set DATABASE_URL to your Neon URL (same string you may keep locally as):
# DATABASE_URL_PRODUCTION="postgresql://user:pass@ep-xxx-pooler.region.neon.tech/neondb?sslmode=require"
# The app only reads DATABASE_URL at runtime; DATABASE_URL_PRODUCTION is optional (reference + CLI migrations).
# Apply migrations to Neon from your machine: npm run db:migrate:neon  (uses DATABASE_URL_PRODUCTION from .env.local)

# --- Web Push (optional) — device notifications for in-app messages ---
# Generate keys: npx web-push generate-vapid-keys
# Never commit the private key. Production requires HTTPS for push to work in browsers.
# VAPID_PUBLIC_KEY="..."
# VAPID_PRIVATE_KEY="..."
# VAPID_SUBJECT="mailto:your-support@example.com"

# =============================================================================
# Vercel (production / preview) — set these in: Project → Settings → Environment Variables
# =============================================================================
# Use "Production" for your live site; add the same keys to "Preview" if you want previews to work end-to-end.
#
# Required:
#   DATABASE_URL          Neon connection string (use the pooled / "serverless" URL if Neon offers it).
#   AUTH_SECRET           openssl rand -base64 32  (same idea as local; never reuse a dev secret in prod if leaked)
#   AUTH_URL              Canonical site URL with NO trailing slash, e.g. https://your-app.vercel.app
#                         or https://your-custom-domain.com  (set this if you use a custom domain; do not rely on VERCEL_URL alone)
#   CRON_SECRET           openssl rand -hex 32  (Vercel Cron sends: Authorization: Bearer <CRON_SECRET> to /api/cron/reminders)
#
# Email (password reset, registration, daily reminder emails from cron):
#   SMTP_HOST, SMTP_PORT, SMTP_SECURE, SMTP_USER, SMTP_PASS, EMAIL_FROM
#
# Web Push (optional; HTTPS on Vercel satisfies browsers):
#   VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY, VAPID_SUBJECT
#
# Vercel sets automatically (do not paste these; reference only):
#   VERCEL_URL, VERCEL_ENV, etc.
